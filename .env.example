#############################################
# CORE WORKFLOW CONFIGURATION
#############################################

# Environment identifier
NODE_ENV=production

# Workflow execution environment
WORKFLOW_TIMEZONE=UTC


#############################################
# FOREPLAY (COMPETITOR AD INTELLIGENCE)
#############################################

# API key for Foreplay public API
FOREPLAY_API_KEY=your_foreplay_api_key_here

# Optional: default competitor brand identifier
FOREPLAY_DEFAULT_BRAND_ID=your_competitor_brand_id


#############################################
# GOOGLE GEMINI (VIDEO ANALYSIS)
#############################################

# Google Gemini API key for multimodal analysis
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model version
GEMINI_MODEL=gemini-pro-vision


#############################################
# ANTHROPIC CLAUDE (STRATEGY ADAPTATION)
#############################################

# Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model version
ANTHROPIC_MODEL=claude-3-sonnet


#############################################
# OPENAI SORA (VIDEO GENERATION)
#############################################

# OpenAI API key for SORA video generation
OPENAI_API_KEY=your_openai_api_key_here

# Optional: SORA model version
SORA_MODEL=sora-2


#############################################
# AIRTABLE (PERSISTENCE & BRAND DATA)
#############################################

# Airtable API key
AIRTABLE_API_KEY=your_airtable_api_key_here

# Airtable Base ID
AIRTABLE_BASE_ID=your_airtable_base_id

# Airtable table names
AIRTABLE_WINNING_ADS_TABLE=Winning_Ads
AIRTABLE_BRAND_CONTEXT_TABLE=Brand_Context
AIRTABLE_GENERATED_CREATIVES_TABLE=Generated_Creatives


#############################################
# SLACK (TEAM NOTIFICATIONS)
#############################################

# Slack Bot Token or Webhook URL
SLACK_BOT_TOKEN=your_slack_bot_token_here

# Slack channel ID for notifications
SLACK_CHANNEL_ID=your_slack_channel_id


#############################################
# EXECUTION SAFETY & LIMITS
#############################################

# Maximum ads processed per run
MAX_ADS_PER_EXECUTION=10

# Enable / disable automatic workflow execution
ENABLE_SCHEDULED_RUNS=true
